// Prisma schema for Vectra
// Supports both SQLite (local dev) and PostgreSQL (Supabase prod)
// The provider is auto-detected from DATABASE_URL — just set DATABASE_URL in your env:
//   - Local dev:  DATABASE_URL="file:./dev.db"
//   - Supabase:   DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Content models (editable via dashboard) =====

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  iconName    String   @default("Code2") // Lucide icon name
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id            String   @id @default(cuid())
  title         String
  category      String
  description   String
  domain        String
  year          String
  mockupFrom    String   @default("#7b39fc") // gradient start
  mockupTo      String   @default("#2b2344") // gradient end
  accent        String   @default("#c4a4ff")
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  name      String
  role      String
  initials  String
  accent    String   @default("from-[#7b39fc] to-[#a484d7]")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stat {
  id        String   @id @default(cuid())
  label     String
  value     Float
  suffix    String   @default("")
  decimals  Int      @default(0)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Analytics =====

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String   // "page_view" | "cta_click" | "session_start"
  name      String   // e.g. "hero", "work", "Lancer un projet"
  visitorId String   // anonymous visitor ID (localStorage)
  path      String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([visitorId])
}

model DailyStat {
  id        String   @id @default(cuid())
  date      String   @unique // YYYY-MM-DD
  visitors  Int      @default(0)
  pageViews Int      @default(0)
  ctaClicks Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
