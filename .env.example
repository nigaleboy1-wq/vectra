# ============================================================
# Vectra — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# Base de données (SQLite par défaut — Prisma)
DATABASE_URL="file:./dev.db"

# NextAuth (authentification — optionnel pour ce site vitrine)
NEXTAUTH_SECRET="generer-avec-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# Optionnel — pour le formulaire de contact en production
# Le formulaire fonctionne sans ça (simulation côté client),
# mais pour envoyer les emails réellement, branchez un service.
# ============================================================

# Resend (recommandé pour Vercel)
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# CONTACT_EMAIL_TO="hello@vectra.studio"

# Ou Formspree
# FORMSPREE_ENDPOINT="https://formspree.io/f/xxxxxxxx"

# ============================================================
# Optionnel — analytics
# ============================================================
# NEXT_PUBLIC_ANALYTICS_ID=""
